# Roboflow Private API Key
# Create a .env file in the root directory and add your key.
# Example: ROBOFLOW_API_KEY="abcdef12345"

ROBOFLOW_API_KEY="YOUR_API_KEY"

# Optional Hugging Face publish targets used by scripts/push_hf.py
# Examples:
# HF_MODEL_REPO_ID="your-username/your-model-repo"
# HF_SPACE_REPO_ID="your-username/your-space-repo"

HF_MODEL_REPO_ID=""
HF_SPACE_REPO_ID=""
